rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn(); } // In real prod, check roles
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidLocalizedString(val) {
      return val is map && val.keys().hasAll(['pt', 'en']) && val.pt is string && val.en is string;
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'location', 'tags', 'images', 'features', 'isPublic', 'createdAt', 'updatedAt'])
        && isValidLocalizedString(data.title)
        && isValidLocalizedString(data.description)
        && data.price is number
        && data.location is string
        && data.location.size() < 256
        && data.tags is list
        && data.tags.size() <= 20
        && data.images is list
        && data.images.size() <= 30
        && data.features is list
        && data.features.size() <= 50
        && data.isPublic is bool
        && data.createdAt is number
        && data.updatedAt is number
        && (!("seoTitle" in data) || isValidLocalizedString(data.seoTitle))
        && (!("seoDescription" in data) || (isValidLocalizedString(data.seoDescription) && data.seoDescription.pt.size() <= 160 && data.seoDescription.en.size() <= 160));
    }

    function isValidLead(data) {
      return data.keys().hasAll(['propertyId', 'name', 'email', 'phone', 'createdAt'])
        && data.propertyId is string
        && data.name is string
        && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string
        && data.email.size() > 0 && data.email.size() <= 100
        && data.phone is string
        && data.phone.size() <= 50
        && data.createdAt is number;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'title', 'text', 'imageUrl', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.title is string && data.title.size() <= 100
        && data.text is string && data.text.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.createdAt is number;
    }

    function isValidSeoSettings(data) {
      return data.keys().hasAll(['titlePt', 'descriptionPt', 'keywordsPt', 'titleEn', 'descriptionEn', 'keywordsEn', 'updatedAt'])
        && data.titlePt is string && data.titlePt.size() <= 200
        && data.descriptionPt is string && data.descriptionPt.size() <= 1000
        && data.keywordsPt is string && data.keywordsPt.size() <= 1000
        && data.titleEn is string && data.titleEn.size() <= 200
        && data.descriptionEn is string && data.descriptionEn.size() <= 1000
        && data.keywordsEn is string && data.keywordsEn.size() <= 1000
        && data.updatedAt is number;
    }

    function isValidSocialSettings(data) {
      return data.keys().hasAll(['facebookUrl', 'instagramUrl', 'linkedinUrl', 'updatedAt'])
        && data.facebookUrl is string && data.facebookUrl.size() <= 1000
        && data.instagramUrl is string && data.instagramUrl.size() <= 1000
        && data.linkedinUrl is string && data.linkedinUrl.size() <= 1000
        && data.updatedAt is number;
    }

    function isValidHeroCarouselSettings(data) {
      return data.keys().hasAll(['images'])
        && data.images is list
        && data.images.size() <= 20;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'author', 'imageUrl', 'content', 'date', 'isPublished', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.author is string && data.author.size() <= 100
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.content is string && data.content.size() <= 50000
        && data.date is string && data.date.size() <= 20
        && data.isPublished is bool
        && data.createdAt is number;
    }

    match /properties/{propertyId} {
      allow get: if isValidId(propertyId) && (isAdmin() || existing().isPublic == true);
      allow list: if isAdmin() || existing().isPublic == true;
      allow create: if isAdmin() && isValidId(propertyId) && isValidProperty(incoming());
      allow update: if isAdmin() && isValidId(propertyId) && isValidProperty(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(propertyId);
    }

    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /crmLeads/{leadId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming());
      allow update: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(testimonialId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId) && (
        (settingId == 'seo' && isValidSeoSettings(incoming())) ||
        (settingId == 'social' && isValidSocialSettings(incoming())) ||
        (settingId == 'hero_carousel' && isValidHeroCarouselSettings(incoming()))
      );
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming());
      allow update: if isAdmin() && isValidId(postId) && isValidBlogPost(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(postId);
    }
  }
}

